<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MixCertificate Editor</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    :root{
      --bg:#f6f7f9;
      --surface:#ffffff;
      --surface-2:#f7f8fa;
      --surface-3:#eff2f6;
      --line:#dfe4eb;
      --line-strong:#cfd6df;
      --text:#111827;
      --text-2:#344054;
      --text-3:#475467;
      --text-4:#667085;
      --brand:#635bff;
      --brand-soft:#eef0ff;
      --success:#16a34a;
      --shadow-sm:0 8px 24px rgba(16,24,40,.06);
      --shadow-md:0 12px 28px rgba(16,24,40,.08);
      --radius-sm:8px;
      --radius-md:12px;
      --radius-lg:16px;
      --radius-xl:20px;
      --space-1:8px;
      --space-2:16px;
      --space-3:24px;
      --space-4:32px;
      --space-5:40px;
      --font-xs:12px;
      --font-sm:13px;
      --font-md:14px;
      --font-lg:16px;
      --font-xl:20px;
      --icon-sm:16px;
      --icon-md:20px;
      --focus-ring:0 0 0 3px rgba(99,91,255,.16);
      --transition-fast:.16s ease;
      --transition-medium:.22s ease;
      --sidebar-width:240px;
      --sidebar-collapsed:64px;
      --inspector-width:280px;
    }
    html,body{height:100%}
    body{
      font-family:Inter,"Segoe UI",system-ui,-apple-system,sans-serif;
      background:var(--bg);
      color:var(--text);
      overflow:hidden;
      line-height:1.5;
      -webkit-font-smoothing:antialiased;
      text-rendering:optimizeLegibility;
    }
    button,input,select,textarea{font:inherit}
    button,input,select,textarea{transition:border-color .16s ease,background-color .16s ease,box-shadow .16s ease}
    button{border:none;background:none;cursor:pointer}
    button:disabled{cursor:not-allowed}
    :focus-visible{
      outline:none;
      box-shadow:var(--focus-ring);
    }
    input:focus,select:focus,textarea:focus{
      outline:none;
      border-color:rgba(99,91,255,.38);
      box-shadow:0 0 0 3px rgba(99,91,255,.10);
    }
    .app{
      height:100vh;
      display:grid;
      grid-template-rows:48px 1fr 40px;
      background:var(--bg);
    }
    .topbar{
      display:grid;
      grid-template-columns:auto 1fr auto;
      align-items:center;
      gap:16px;
      padding:0 12px 0 16px;
      border-bottom:1px solid rgba(15,23,42,.06);
      background:var(--surface);
      position:relative;
      z-index:40;
    }
    .topbar-left,.topbar-center,.topbar-right{display:flex;align-items:center;gap:8px;min-width:0}
    .topbar-center{justify-content:center}
    .topbar-right{justify-content:flex-end}
    .logo-lockup{display:flex;align-items:center;gap:10px;min-width:0}
    .icon-btn{
      width:32px;
      height:32px;
      border:1px solid var(--line);
      border-radius:10px;
      background:var(--surface);
      color:var(--text-3);
      display:flex;
      align-items:center;
      justify-content:center;
    }
    .icon-btn:hover{background:var(--surface-2);color:var(--text)}
    .icon-btn svg{width:var(--icon-sm);height:var(--icon-sm);stroke:currentColor;fill:none}
    .brand-mark{
      width:28px;
      height:28px;
      border-radius:9px;
      background:var(--brand);
      color:#fff;
      display:flex;
      align-items:center;
      justify-content:center;
      flex-shrink:0;
    }
    .brand-mark svg{width:14px;height:14px;fill:currentColor}
    .doc-name{
      min-width:140px;
      max-width:320px;
      height:32px;
      padding:0 10px;
      border:1px solid transparent;
      border-radius:8px;
      display:flex;
      align-items:center;
      font-size:14px;
      font-weight:700;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }
    .doc-name:hover,.doc-name:focus{border-color:var(--line);background:var(--surface-2)}
    .top-group{
      display:flex;
      align-items:center;
      gap:6px;
      padding:0;
      height:36px;
      border:none;
      border-radius:0;
      background:transparent;
    }
    .zoom-readout{
      min-width:52px;
      text-align:center;
      font-size:12px;
      font-weight:700;
      color:var(--text-2);
    }
    .action-btn{
      height:32px;
      padding:0 12px;
      border:1px solid rgba(15,23,42,.08);
      border-radius:10px;
      background:var(--surface);
      color:var(--text);
      display:flex;
      align-items:center;
      gap:8px;
      font-size:var(--font-sm);
      font-weight:600;
    }
    .action-btn svg{width:var(--icon-sm);height:var(--icon-sm);stroke:currentColor;fill:none}
    .action-btn:hover{background:var(--surface-2);border-color:var(--line-strong)}
    .profile{
      width:32px;
      height:32px;
      border-radius:50%;
      background:#ecefff;
      color:var(--brand);
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:12px;
      font-weight:700;
      border:1px solid #dfe2ff;
    }
    .workspace{
      display:flex;
      height:100%;
      position:relative;
      overflow:hidden;
    }
    .sidebar{
      display:flex;
      flex-direction:row;
      align-items:stretch;
      height:100%;
      z-index:50;
      flex-shrink:0;
    }
    .sidebar-head{
      width:var(--sidebar-width);
      height:56px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      padding:0 12px;
      border-bottom:1px solid rgba(15,23,42,.05);
    }
    .sidebar-title{
      display:flex;
      align-items:center;
      gap:10px;
      min-width:0;
    }
    .sidebar-title strong{font-size:14px}
    .sidebar-title span{font-size:12px;color:var(--text-3);display:block}
    .app.sidebar-collapsed .sidebar-title-copy{display:none}
    .sidebar-body{
      width:var(--sidebar-width);
      flex:1;
      min-height:0;
      overflow-x:hidden;
      overflow-y:auto;
      padding:16px 16px 24px;
      display:flex;
      flex-direction:column;
      gap:24px;
      align-items:stretch;
      overscroll-behavior:contain;
    }
    .sidebar-body::-webkit-scrollbar,.inspector-body::-webkit-scrollbar{width:8px}
    .sidebar-body::-webkit-scrollbar-thumb,.inspector-body::-webkit-scrollbar-thumb{background:#d6dbe4;border-radius:999px}
    .sidebar-sticky{
      position:sticky;
      top:0;
      z-index:6;
      display:flex;
      flex-direction:column;
      gap:12px;
      padding-bottom:12px;
      background:linear-gradient(180deg,#fafbfc 0%,#fafbfc 78%,rgba(250,251,252,0) 100%);
    }
    .accordion{
      position:relative;
      border:1px solid rgba(15,23,42,.06);
      border-radius:16px;
      background:rgba(255,255,255,.84);
      overflow:hidden;
      isolation:isolate;
    }
    .accordion-head{
      width:100%;
      min-height:52px;
      padding:12px;
      display:flex;
      align-items:center;
      gap:12px;
      color:var(--text);
      text-align:left;
    }
    .accordion-icon{
      width:28px;
      height:28px;
      border-radius:10px;
      background:var(--surface-3);
      color:var(--text-2);
      display:flex;
      align-items:center;
      justify-content:center;
      flex-shrink:0;
    }
    .accordion-icon svg{width:15px;height:15px;stroke:currentColor;fill:none}
    .accordion-copy{flex:1;min-width:0}
    .accordion-copy strong{display:block;font-size:13px}
    .accordion-copy span{display:block;margin-top:2px;font-size:12px;color:var(--text-3);line-height:1.4}
    .accordion-caret{
      width:16px;
      height:16px;
      color:var(--text-4);
      flex-shrink:0;
    }
    .accordion-caret svg{width:16px;height:16px;stroke:currentColor;fill:none}
    .accordion-body{
      display:grid;
      grid-template-columns:minmax(0,1fr);
      gap:16px;
      max-height:0;
      overflow:hidden;
      padding:0 12px;
      background:transparent;
      opacity:0;
      transition:max-height .24s ease, opacity .18s ease, padding .18s ease;
    }
    .accordion.open .accordion-body{
      padding:0 12px 16px;
      opacity:1;
    }
    .app.sidebar-collapsed .accordion{
      border:none;
      border-radius:12px;
      background:transparent;
    }
    .app.sidebar-collapsed .accordion-head{
      justify-content:center;
      padding:10px 6px;
    }
    .app.sidebar-collapsed .accordion-copy,
    .app.sidebar-collapsed .accordion-caret,
    .app.sidebar-collapsed .accordion-body{display:none}
    .app.sidebar-collapsed .search input{display:none}
    .app.sidebar-collapsed .search{padding:0; justify-content:center; border-color:transparent; background:transparent;}
    .search{
      height:40px;
      display:flex;
      align-items:center;
      gap:var(--space-1);
      border:1px solid var(--line);
      border-radius:var(--radius-md);
      padding:0 12px;
      background:var(--surface-2);
      margin-top:0;
    }
    .search svg{width:var(--icon-sm);height:var(--icon-sm);stroke:var(--text-4);fill:none}
    .search input{
      flex:1;
      border:none;
      background:none;
      color:var(--text);
      font-size:var(--font-sm);
    }
    .workspace-search{margin-bottom:0}
    .toolbar-row{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      margin-top:0;
    }
    .panel-tabs{
      display:flex;
      gap:8px;
      margin-top:0;
      overflow:auto;
      scrollbar-width:none;
      min-width:0;
    }
    .panel-tabs::-webkit-scrollbar{display:none}
    .panel-tab{
      min-height:40px;
      padding:0 12px;
      border:1px solid var(--line);
      border-radius:999px;
      background:var(--surface);
      color:var(--text-2);
      font-size:var(--font-xs);
      font-weight:700;
      white-space:nowrap;
    }
    .panel-tab:hover{border-color:var(--line-strong);background:var(--surface-2)}
    .panel-tab.active{
      background:var(--brand-soft);
      border-color:#d9dbff;
      color:var(--brand);
    }
    .panel-pane{display:none;min-width:0}
    .panel-pane.active{
      display:grid;
      grid-template-columns:minmax(0,1fr);
      gap:16px;
      min-width:0;
    }
    .accordion-body > *,
    .panel-pane > *{min-width:0}
    .chip{
      min-height:40px;
      padding:0 10px;
      border:1px solid var(--line);
      border-radius:999px;
      background:var(--surface);
      color:var(--text-2);
      font-size:var(--font-xs);
      font-weight:600;
    }
    .chip:hover{border-color:var(--line-strong);background:var(--surface-2);color:var(--text)}
    .chip.active{
      background:var(--brand-soft);
      border-color:#d9dbff;
      color:var(--brand);
    }
    .grid-2{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;margin-top:0}
    .feature-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;margin-top:0}
    .template-card,.asset-card,.quick-card{
      border:1px solid var(--line);
      border-radius:12px;
      background:var(--surface);
      overflow:hidden;
      transition:transform var(--transition-fast),border-color var(--transition-fast),background-color var(--transition-fast),box-shadow var(--transition-fast);
    }
    .template-card,.asset-card{cursor:pointer}
    .template-card:hover,.asset-card:hover,.quick-card:hover{border-color:var(--line-strong);transform:translateY(-1px)}
    .template-card.selected,.asset-card.selected{border-color:var(--brand);box-shadow:0 0 0 1px rgba(99,91,255,.10)}
    .template-preview,.asset-preview{
      aspect-ratio:1.45/1;
      position:relative;
    }
    .template-info,.asset-info{padding:10px}
    .template-info strong,.asset-info strong{display:block;font-size:13px}
    .template-info span,.asset-info span{display:block;margin-top:4px;font-size:12px;color:var(--text-3)}
    .tool-card{
      border:1px solid var(--line);
      border-radius:12px;
      background:var(--surface);
      overflow:hidden;
      text-align:left;
      transition:transform var(--transition-fast),border-color var(--transition-fast),background-color var(--transition-fast);
    }
    .tool-card:hover{border-color:var(--line-strong);transform:translateY(-1px)}
    .tool-thumb{
      height:84px;
      border-bottom:1px solid rgba(15,23,42,.05);
      background:var(--surface-2);
      position:relative;
      display:flex;
      align-items:center;
      justify-content:center;
      color:var(--text-2);
    }
    .tool-thumb svg{width:34px;height:34px;stroke:currentColor;fill:none}
    .tool-meta{padding:10px}
    .tool-meta strong{display:block;font-size:var(--font-sm)}
    .tool-meta span{display:block;margin-top:4px;font-size:var(--font-xs);color:var(--text-3)}
    .stack-list{display:flex;flex-direction:column;gap:12px;margin-top:0;min-width:0}
    .list-row{
      min-height:42px;
      padding:10px 12px;
      border:1px solid var(--line);
      border-radius:10px;
      background:var(--surface);
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
    }
    .list-row strong{font-size:var(--font-sm)}
    .list-row span{font-size:var(--font-xs);color:var(--text-3)}
    .secondary-meta{font-size:11px;color:var(--text-4);font-weight:700;white-space:nowrap}
    .variable-chips,.drag-pills,.brand-swatch-row,.font-preset-row{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      margin-top:0;
    }
    .variable-chip,.drag-pill,.font-preset{
      display:inline-flex;
      align-items:center;
      gap:8px;
      min-height:40px;
      padding:0 10px;
      border:1px solid var(--line);
      border-radius:999px;
      background:var(--surface);
      font-size:var(--font-xs);
      font-weight:700;
      color:var(--text-2);
    }
    .variable-chip:hover,.drag-pill:hover,.font-preset:hover{border-color:var(--line-strong);background:var(--surface-2)}
    .drag-pill{cursor:grab}
    .mini-badge{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:18px;
      height:18px;
      padding:0 6px;
      border-radius:999px;
      background:var(--surface-3);
      color:var(--text-3);
      font-size:10px;
      font-weight:700;
    }
    .qr-preview{
      margin-top:0;
      border:1px solid var(--line);
      border-radius:12px;
      background:var(--surface);
      padding:14px;
      display:flex;
      align-items:center;
      gap:12px;
      min-width:0;
    }
    .qr-preview .qr-box{width:88px;height:88px;margin:0}
    .signature-grid{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:12px;
      margin-top:0;
    }
    .signature-card{
      min-height:84px;
      padding:12px;
      border:1px solid var(--line);
      border-radius:12px;
      background:var(--surface);
      text-align:left;
    }
    .signature-card strong{display:block;font-size:var(--font-sm)}
    .signature-card span{display:block;margin-top:8px;font-size:var(--font-xs);color:var(--text-3)}
    .draw-pad{
      height:96px;
      margin-top:0;
      border:1px dashed var(--line-strong);
      border-radius:12px;
      background:linear-gradient(180deg,#ffffff,#fafbfc);
      display:flex;
      align-items:center;
      justify-content:center;
      color:var(--text-4);
      font-size:var(--font-xs);
    }
    .style-stack{display:flex;flex-direction:column;gap:12px;margin-top:0}
    .style-row{
      min-height:44px;
      padding:10px 12px;
      border:1px solid var(--line);
      border-radius:10px;
      background:var(--surface);
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
    }
    .style-row strong{display:block;font-size:var(--font-sm)}
    .style-row span{display:block;font-size:var(--font-xs);color:var(--text-3)}
    .brand-logo-row{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:12px;
      margin-top:0;
    }
    .logo-tile{
      min-height:72px;
      border:1px solid var(--line);
      border-radius:12px;
      background:var(--surface);
      display:flex;
      align-items:center;
      justify-content:center;
      color:var(--text-2);
      font-size:var(--font-xs);
      font-weight:700;
    }
    .brand-swatch{
      width:24px;
      height:24px;
      border-radius:8px;
      border:1px solid rgba(15,23,42,.08);
    }
    .text-preview{
      min-height:76px;
      padding:12px;
      border:1px solid var(--line);
      border-radius:12px;
      background:var(--surface);
      text-align:left;
    }
    .text-preview .preview-title{font-size:18px;font-weight:800;line-height:1.2;color:#4c3420}
    .text-preview .preview-body{margin-top:6px;font-size:12px;color:var(--text-3)}
    .ai-mode-switch{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:8px;
      margin-top:0;
    }
    .ai-step-list{
      display:flex;
      flex-direction:column;
      gap:16px;
      margin-top:0;
    }
    .ai-step{
      padding:12px;
      border:1px solid var(--line);
      border-radius:12px;
      background:var(--surface);
    }
    .ai-step strong{display:block;font-size:var(--font-sm)}
    .ai-step span{display:block;margin-top:4px;font-size:var(--font-xs);color:var(--text-3)}
    .mini-cert{
      position:absolute;
      inset:10px;
      border-radius:10px;
      background:rgba(255,255,255,.78);
      display:flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      gap:6px;
      color:#4c3420;
      text-align:center;
    }
    .mini-cert .l1{font-size:8px;font-weight:800;letter-spacing:.08em}
    .mini-cert .l2{font-size:11px;font-weight:800}
    .mini-cert .l3{font-size:8px}
    .quick-card{
      padding:14px;
      min-height:110px;
      display:flex;
      flex-direction:column;
      gap:12px;
      background:var(--surface-2);
    }
    .quick-card strong{font-size:var(--font-sm)}
    .quick-card p{font-size:var(--font-xs);line-height:1.5;color:var(--text-3)}
    .quick-icon{
      width:32px;
      height:32px;
      border-radius:10px;
      background:var(--surface-3);
      color:var(--text-2);
      display:flex;
      align-items:center;
      justify-content:center;
    }
    .quick-icon svg{width:var(--icon-sm);height:var(--icon-sm);stroke:currentColor;fill:none}
    .field{margin-top:12px}
    .accordion-body > .field,
    .panel-pane > .field,
    .accordion-body > .subsection-label,
    .panel-pane > .subsection-label{margin-top:0}
    .field label{
      display:block;
      margin-bottom:8px;
      font-size:13px;
      font-weight:700;
      color:var(--text-2);
    }
    .input,.select,.textarea{
      width:100%;
      border:1px solid var(--line);
      border-radius:12px;
      background:var(--surface);
      color:var(--text);
    }
    .input,.select{height:40px;padding:0 12px;font-size:var(--font-sm)}
    .textarea{min-height:96px;padding:12px;font-size:var(--font-sm);line-height:1.5;resize:vertical}
    .theme-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:12px}
    .accordion-body > .theme-grid,
    .panel-pane > .theme-grid{margin-top:0}
    .theme-btn{
      height:36px;
      border:1px solid var(--line);
      border-radius:12px;
      background:var(--surface);
      color:var(--text-2);
      font-size:var(--font-xs);
      font-weight:700;
    }
    .theme-btn:hover{border-color:var(--line-strong);background:var(--surface-2)}
    .theme-btn.on{
      background:var(--brand-soft);
      border-color:#d9dbff;
      color:var(--brand);
    }
    .upload-box{
      margin-top:0;
      border:1px dashed var(--line-strong);
      border-radius:12px;
      padding:16px;
      background:var(--surface-2);
      text-align:center;
    }
    .upload-box p{margin-top:8px;font-size:12px;line-height:1.5;color:var(--text-3)}
    .upload-actions{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-top:12px}
    .secondary-btn,.primary-btn,.utility-btn{
      min-height:40px;
      padding:0 12px;
      border-radius:10px;
      font-size:var(--font-xs);
      font-weight:700;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:8px;
      transition:background-color var(--transition-fast),border-color var(--transition-fast),box-shadow var(--transition-fast),transform var(--transition-fast),color var(--transition-fast);
    }
    .secondary-btn{
      border:1px solid var(--line);
      background:var(--surface);
      color:var(--text-2);
    }
    .secondary-btn:hover,.utility-btn:hover{background:var(--surface-2);border-color:var(--line-strong);color:var(--text)}
    .primary-btn{
      border:1px solid var(--brand);
      background:var(--brand);
      color:#fff;
    }
    .primary-btn:hover{filter:brightness(.97)}
