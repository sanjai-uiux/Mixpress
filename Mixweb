                <svg viewBox="0 0 20 20"><path d="M10 3l1.7 5.2H17l-4.3 3.1 1.6 5L10 13.6 5.7 16.3l1.6-5L3 8.2h5.3z" stroke-width="1.4" stroke-linejoin="round"/></svg>
