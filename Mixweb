      border-top-color:var(--brand);
      border-radius:50%;
      animation:spin .7s linear infinite;
    }
    @keyframes spin{
      to{transform:rotate(360deg)}
    }
    @media (prefers-reduced-motion: reduce){
      *,
      *::before,
      *::after{
        animation:none !important;
        transition:none !important;
        scroll-behavior:auto !important;
      }
    }
    .color-popover{
      position:fixed;
      width:332px;
      border:1px solid var(--line);
      border-radius:20px;
      background:var(--surface);
      box-shadow:var(--shadow-sm);
      padding:16px;
      z-index:90;
      display:none;
    }
    .color-popover.show{display:block}
    .picker-sv{
      position:relative;
      height:220px;
      border:1px solid var(--line);
      border-radius:16px;
      overflow:hidden;
      cursor:crosshair;
      background:red;
    }
    .picker-sv::before{
      content:"";
      position:absolute;
      inset:0;
      background:linear-gradient(90deg,#fff,rgba(255,255,255,0));
    }
    .picker-sv::after{
      content:"";
      position:absolute;
      inset:0;
      background:linear-gradient(180deg,rgba(0,0,0,0),#000);
    }
    .picker-handle{
      position:absolute;
      width:18px;
      height:18px;
      border-radius:50%;
      border:3px solid #fff;
      box-shadow:0 1px 4px rgba(17,24,39,.28);
      transform:translate(-50%,-50%);
      pointer-events:none;
    }
    .picker-bar{
      margin-top:14px;
      display:flex;
      align-items:center;
      gap:10px;
    }
    .picker-bar label{
      width:18px;
      font-size:12px;
      color:var(--text-3);
      text-align:center;
    }
    .range{
      -webkit-appearance:none;
      appearance:none;
      width:100%;
      height:12px;
      border-radius:999px;
      border:none;
      outline:none;
    }
    .range::-webkit-slider-thumb{
      -webkit-appearance:none;
      appearance:none;
      width:18px;
      height:18px;
      border-radius:50%;
      border:3px solid #fff;
      box-shadow:0 1px 4px rgba(17,24,39,.28);
      background:#fff;
    }
    .range::-moz-range-thumb{
      width:18px;
      height:18px;
      border-radius:50%;
      border:3px solid #fff;
      box-shadow:0 1px 4px rgba(17,24,39,.28);
      background:#fff;
    }
    .hue-range{background:linear-gradient(90deg,#ff0000 0%,#ffff00 17%,#00ff00 33%,#00ffff 50%,#0000ff 67%,#ff00ff 83%,#ff0000 100%)}
    .alpha-range{background:linear-gradient(90deg,transparent,#000)}
    .picker-meta{
      display:grid;
      grid-template-columns:72px 1fr 72px;
      margin-top:14px;
      border:1px solid var(--line);
      border-radius:12px;
      overflow:hidden;
    }
    .picker-meta select,.picker-meta input{
      height:42px;
      border:none;
      background:var(--surface);
      padding:0 12px;
      font-size:13px;
    }
    .picker-alpha{
      display:flex;
      align-items:center;
      justify-content:center;
      border-left:1px solid var(--line);
      background:var(--surface-2);
      font-size:13px;
      font-weight:700;
      color:var(--text-2);
    }
    .picker-swatches{
      margin-top:14px;
      display:grid;
      grid-template-columns:repeat(8,1fr);
      gap:8px;
    }
    .picker-swatch{
      width:100%;
      aspect-ratio:1/1;
      border-radius:10px;
      border:1px solid var(--line);
      cursor:pointer;
    }
    .bottombar{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      padding:0 16px;
      border-top:1px solid rgba(15,23,42,.06);
      background:rgba(255,255,255,.94);
      font-size:12px;
      color:var(--text-3);
    }
    .bottom-group{display:flex;align-items:center;gap:16px;min-width:0}
    .bottom-pill{
      display:flex;
      align-items:center;
      gap:6px;
      white-space:nowrap;
    }
    .status-dot{
      width:8px;
      height:8px;
      border-radius:50%;
      background:var(--success);
    }
    .shortcut-copy{white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    @media (max-width: 1280px){
      .ruler-top{width:960px}
      .ruler-left{height:679px}
      .cert-stage,.cert{width:960px}
      .cert-title{font-size:64px}
      .cert-subtitle{font-size:50px}
      .cert-name{font-size:52px}
    }
    @media (max-width: 1080px){
      .topbar{
        grid-template-columns:auto 1fr auto;
      }
      .topbar-center{justify-content:flex-start}

      .sidebar{
        width:72px;
        overflow:visible;
      }
      .toolrail{
        margin:12px 0 12px 12px;
        border:1px solid rgba(15,23,42,.06);
        border-radius:16px;
        box-shadow:var(--shadow-md);
        background:#fafbfc;
      }
      .toolpanel{
        position:absolute;
        left:84px;
        top:12px;
        bottom:12px;
        width:min(344px,calc(100vw - 108px));
        border:1px solid rgba(15,23,42,.06);
        border-radius:16px;
        box-shadow:var(--shadow-md);
        overflow:hidden;
      }
      .app.toolpanel-closed .toolpanel{
        transform:translateX(-16px);
      }
      .inspector{
        position:absolute;
        right:12px;
        top:12px;
        bottom:12px;
        width:min(288px,calc(100vw - 24px));
        border:1px solid rgba(15,23,42,.06);
        border-radius:12px;
        box-shadow:var(--shadow-md);
        z-index:60;
        transform: translateX(120%);
      }
      .context-strip{
        left:16px;
        right:16px;
      }
      .canvas-scroller{padding:28px 24px 40px}
    }
    @media (max-width: 720px){
      .topbar{
        grid-template-columns:auto 1fr auto;
        padding:0 8px 0 12px;
        gap:8px;
      }
      .topbar-right .action-btn span,
      .topbar-left .doc-name{max-width:140px}
      .topbar-right .action-btn{padding:0 10px}
      .topbar-right .action-btn:nth-child(4){display:none}
      .toolrail{
        width:64px;
        margin:12px 0 12px 8px;
        padding:8px 6px;
      }
      .toolnav-btn span{font-size:9px}
      .toolpanel{
        left:12px;
        right:12px;
        bottom:12px;
        top:auto;
        width:auto;
        height:min(72vh,620px);
        border-radius:20px;
        transform:translateY(0);
      }
      .app.toolpanel-closed .toolpanel{
        transform:translateY(108%);
      }
      .context-strip{
        top:6px;
        left:12px;
        right:12px;
        height:auto;
        min-height:36px;
        align-items:flex-start;
        flex-direction:column;
        padding:0;
      }
      .canvas-scroller{padding:44px 12px 36px}
      .canvas-inner{min-width:744px}
      .ruler-top{width:720px}
      .ruler-left{height:509px}
      .cert-stage,.cert{width:720px}
      .cert-content{inset:64px 48px 64px}
      .cert-title{font-size:52px}
      .cert-subtitle{font-size:40px}
      .cert-copy{font-size:20px}
      .cert-name{font-size:42px;min-width:0;width:100%}
      .inspector{
        top:auto;
        left:0;
        right:0;
        bottom:0;
        width:auto;
        height:min(72vh,560px);
        border-radius:20px 20px 0 0;
        border-left:none;
        border-right:none;
        border-bottom:none;
      }
    }
  </style>
</head>
<body>
