  <div class="toast" id="toast" role="status" aria-live="polite"></div>

  <script>
    const app = document.getElementById("app");
    const cert = document.getElementById("certEl");
    const rulerFrame = document.querySelector(".ruler-frame");
    const canvasScroll = document.getElementById("canvasScroll");
    const toolpanel = document.getElementById("toolpanel");
    const toolpanelBody = document.getElementById("toolpanelBody");
    const toolpanelTitle = document.getElementById("toolpanelTitle");
    const toolpanelDesc = document.getElementById("toolpanelDesc");
    const toolNavButtons = Array.from(document.querySelectorAll(".toolnav-btn"));
    const toolModules = Array.from(document.querySelectorAll(".tool-module"));
    const toast = document.getElementById("toast");
    const zoomTop = document.getElementById("zoomTop");
    const zoomBottom = document.getElementById("zoomBottom");
    const statusText = document.getElementById("statusText");
    const contextStrip = document.querySelector(".context-strip");
    const contextSummary = document.getElementById("contextSummary");
    const colorPopover = document.getElementById("colorPopover");
    const pickerSv = document.getElementById("pickerSv");
    const pickerHandle = document.getElementById("pickerHandle");
    const hueRange = document.getElementById("hueRange");
    const alphaRange = document.getElementById("alphaRange");
    const pickerHex = document.getElementById("pickerHex");
    const pickerAlphaValue = document.getElementById("pickerAlphaValue");
    const inspectorTitle = document.getElementById("inspectorTitle");
    const inspectorSubtitle = document.getElementById("inspectorSubtitle");
    const modeCanvas = document.getElementById("modeCanvas");
    const modeText = document.getElementById("modeText");
    const modeImage = document.getElementById("modeImage");
    const modeShape = document.getElementById("modeShape");
    const modeMulti = document.getElementById("modeMulti");
    const multiSelectionCount = document.getElementById("multiSelectionCount");
    const pageColorTrigger = document.getElementById("pageColorTrigger");
    const pageColorValue = document.getElementById("pageColorValue");
    const rulerToggle = document.getElementById("rulerToggle");
    const textColorTrigger = document.getElementById("textColorTrigger");
    const textColorValue = document.getElementById("textColorValue");
    const shapeColorTrigger = document.getElementById("shapeColorTrigger");
    const shapeColorValue = document.getElementById("shapeColorValue");
    const layerList = document.getElementById("layerList");
    const alignLeftBtn = document.getElementById("alignLeftBtn");
    const alignCenterBtn = document.getElementById("alignCenterBtn");
    const alignRightBtn = document.getElementById("alignRightBtn");
    const distributeHorizontalBtn = document.getElementById("distributeHorizontalBtn");
    const distributeVerticalBtn = document.getElementById("distributeVerticalBtn");
    const bringForwardBtn = document.getElementById("bringForwardBtn");
    const sendBackwardBtn = document.getElementById("sendBackwardBtn");
    const bringToFrontBtn = document.getElementById("bringToFrontBtn");
    const sendToBackBtn = document.getElementById("sendToBackBtn");
    const duplicateBtn = document.getElementById("duplicateBtn");
    const deleteBtn = document.getElementById("deleteBtn");
    const arrangeFrontBtn = document.getElementById("arrangeFrontBtn");
    const arrangeBackBtn = document.getElementById("arrangeBackBtn");
    const duplicateQuickBtn = document.getElementById("duplicateQuickBtn");
    const designObjects = Array.from(document.querySelectorAll(".design-object"));
    let zoom = 100;
    let toastTimer = null;
    let activeColorTarget = null;
    let pickerState = { h: 197, s: 0.07, v: 1, a: 1 };
    let selectedObjects = [];
    let objectCounter = designObjects.length;
    let busyTimer = null;
    let activeTool = "templates";
    const toolScrollPositions = {};

    function showToast(message) {
      clearTimeout(toastTimer);
      toast.textContent = message;
      toast.style.display = "block";
      toastTimer = setTimeout(() => {
        toast.style.display = "none";
      }, 1800);
    }

    function clamp(value, min, max) {
      return Math.min(max, Math.max(min, value));
    }

    function normalizeHex(value, fallback) {
      const raw = (value || "").trim().replace(/^#/, "");
      if (/^[0-9a-fA-F]{6}$/.test(raw)) {
      return "#" + raw.toUpperCase();
      }
      return fallback;
    }

    function setButtonLoading(button, loading) {
      if (!button) return;
      button.classList.toggle("is-loading", loading);
      button.setAttribute("aria-busy", loading ? "true" : "false");
      if (loading) {
        button.dataset.prevDisabled = button.disabled ? "true" : "false";
        button.disabled = true;
      } else if (button.dataset.prevDisabled !== "true") {
        button.disabled = false;
      }
    }

    function runAsyncFeedback(button, message, delay = 650) {
      clearTimeout(busyTimer);
      setButtonLoading(button, true);
      busyTimer = setTimeout(() => {
        setButtonLoading(button, false);
        showToast(message);
      }, delay);
    }

    function getToolMeta(name) {
      const button = toolNavButtons.find((item) => item.dataset.tool === name);
      const module = toolModules.find((item) => item.dataset.module === name);
      const title = module?.querySelector(".accordion-copy strong")?.textContent || button?.querySelector("span")?.textContent || "Workspace";
      const desc = module?.querySelector(".accordion-copy span")?.textContent || "";
      return { title, desc };
    }

    function openTool(name, preserveScroll = true) {
      if (activeTool && preserveScroll) {
        toolScrollPositions[activeTool] = toolpanelBody.scrollTop;
      }
      activeTool = name;
      const meta = getToolMeta(name);
      toolpanelTitle.textContent = meta.title;
      toolpanelDesc.textContent = meta.desc;
      toolNavButtons.forEach((button) => {
        button.classList.toggle("active", button.dataset.tool === name);
        button.setAttribute("aria-pressed", button.dataset.tool === name ? "true" : "false");
      });
      toolModules.forEach((section) => {
        section.classList.toggle("active", section.dataset.module === name);
      });
      app.classList.remove("toolpanel-closed");
      requestAnimationFrame(() => {
        toolpanelBody.scrollTop = toolScrollPositions[name] || 0;
      });
    }

    function closeToolPanel() {
      if (activeTool) {
        toolScrollPositions[activeTool] = toolpanelBody.scrollTop;
      }
      app.classList.add("toolpanel-closed");
    }

    function toggleToolPanel() {
      if (app.classList.contains("toolpanel-closed")) {
        openTool(activeTool || "templates", false);
      } else {
        closeToolPanel();
      }
    }

    function syncAccordionHeight(section) {
      if (!section) return;
      const body = section.querySelector(".accordion-body");
      if (!body) return;
      if (!section.classList.contains("open")) {
        body.style.maxHeight = "0px";
        return;
      }
      body.style.maxHeight = body.scrollHeight + "px";
    }

    function syncAllAccordionHeights() {
      document.querySelectorAll(".accordion").forEach(syncAccordionHeight);
    }

    function normalizeObject(node) {
      const left = node.offsetLeft;
      const top = node.offsetTop;
      const width = node.offsetWidth;
      const height = node.offsetHeight;
      node.style.left = left + "px";
      node.style.top = top + "px";
      node.style.width = width + "px";
      node.style.height = height + "px";
      node.style.right = "auto";
      node.style.bottom = "auto";
      if (!node.dataset.objectId) {
        objectCounter += 1;
        node.dataset.objectId = "object-" + objectCounter;
      }
      if (!node.dataset.z) {
        node.dataset.z = String(parseInt(window.getComputedStyle(node).zIndex, 10) || 2);
        node.style.zIndex = node.dataset.z;
      }
      node.tabIndex = 0;
      node.setAttribute("role", "button");
      node.setAttribute("aria-label", node.dataset.objectName + ", " + node.dataset.objectType);
      node.setAttribute("aria-pressed", "false");
    }

    function registerObject(node) {
      normalizeObject(node);
      node.addEventListener("click", (event) => {
        event.stopPropagation();
        const additive = event.ctrlKey || event.metaKey || event.shiftKey;
        if (additive) {
          if (selectedObjects.includes(node)) {
            setSelectionState(selectedObjects.filter((item) => item !== node));
          } else {
            setSelectionState([...selectedObjects, node]);
          }
          return;
        }
        setSelectionState([node]);
      });
      node.addEventListener("keydown", (event) => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          const additive = event.ctrlKey || event.metaKey || event.shiftKey;
          if (additive) {
            if (selectedObjects.includes(node)) {
              setSelectionState(selectedObjects.filter((item) => item !== node));
            } else {
              setSelectionState([...selectedObjects, node]);
            }
            return;
          }
          setSelectionState([node]);
        }
      });
    }

    function setInspectorMode(mode) {
      [modeCanvas, modeText, modeImage, modeShape, modeMulti].forEach((section) => {
        section.classList.remove("active");
      });
      if (mode === "canvas") {
        inspectorTitle.textContent = "Canvas";
        inspectorSubtitle.textContent = "Canvas, page, and export settings.";
        modeCanvas.classList.add("active");
      } else if (mode === "text") {
        inspectorTitle.textContent = "Text";
        inspectorSubtitle.textContent = "Typography, alignment, and text styling controls.";
        modeText.classList.add("active");
      } else if (mode === "image") {
        inspectorTitle.textContent = "Image";
        inspectorSubtitle.textContent = "Media replacement, crop, and visual adjustments.";
        modeImage.classList.add("active");
      } else if (mode === "shape") {
        inspectorTitle.textContent = "Shape";
        inspectorSubtitle.textContent = "Fill, stroke, shadows, and sizing controls.";
        modeShape.classList.add("active");
      } else if (mode === "multi") {
        inspectorTitle.textContent = "Multi-select";
        inspectorSubtitle.textContent = "Alignment and arrangement for multiple objects.";
        modeMulti.classList.add("active");
      }
    }

    function renderLayerList() {
      if (!layerList) return;
      if (!designObjects.length) {
        layerList.innerHTML = '<div class="empty-card">No layers yet. Add text, shapes, or media to start building the certificate.</div>';
        return;
      }
      const ordered = designObjects.slice().sort((a, b) => getObjectZ(b) - getObjectZ(a));
      layerList.innerHTML = ordered.map((node) => {
        const active = selectedObjects.includes(node) ? " active" : "";
        return '<button class="layer-item' + active + '" data-layer-id="' + node.dataset.objectId + '">' +
          '<div><strong>' + node.dataset.objectName + '</strong><span>Layer ' + node.dataset.z + '</span></div>' +
          '<div class="layer-type">' + node.dataset.objectType + '</div>' +
        '</button>';
      }).join("");
    }

    function updateContextState() {
      const hasSelection = selectedObjects.length > 0;
      contextStrip.classList.toggle("selection-active", hasSelection);
      [alignLeftBtn, alignCenterBtn, alignRightBtn, bringForwardBtn, sendBackwardBtn, bringToFrontBtn, sendToBackBtn, duplicateBtn, deleteBtn, arrangeFrontBtn, arrangeBackBtn, duplicateQuickBtn].forEach((button) => {
        button.disabled = !hasSelection;
      });
      [distributeHorizontalBtn, distributeVerticalBtn].forEach((button) => {
        button.disabled = selectedObjects.length < 2;
      });
      if (!hasSelection) {
        contextSummary.textContent = "No object selected";
        statusText.textContent = "Canvas settings";
        multiSelectionCount.value = "0 objects";
        setInspectorMode("canvas");
        renderLayerList();
        return;
      }
      if (selectedObjects.length > 1) {
        contextSummary.textContent = selectedObjects.length + " objects selected";
        statusText.textContent = "Multi-select active";
        multiSelectionCount.value = selectedObjects.length + " objects";
        setInspectorMode("multi");
        renderLayerList();
        return;
      }
      const active = selectedObjects[0];
      contextSummary.textContent = active.dataset.objectName;
      statusText.textContent = active.dataset.objectType + " selected";
      setInspectorMode(active.dataset.objectType);
      syncInspectorColors(active);
      renderLayerList();
    }

    function syncInspectorColors(active) {
      if (!active) return;
      if (active.dataset.objectType === "text") {
        const textColor = active.dataset.color || "#4C3420";
        textColorTrigger.dataset.color = textColor;
        textColorTrigger.style.background = textColor;
        textColorValue.value = textColor;
      }
      if (active.dataset.objectType === "shape") {
        const shapeColor = active.dataset.color || "#9DD86F";
        shapeColorTrigger.dataset.color = shapeColor;
        shapeColorTrigger.style.background = shapeColor;
        shapeColorValue.value = shapeColor;
      }
    }

    function setSelectionState(nextSelection) {
      selectedObjects = nextSelection;
      designObjects.forEach((node) => {
        node.classList.remove("selected", "multi");
        node.setAttribute("aria-pressed", "false");
      });
      selectedObjects.forEach((node) => {
        node.classList.add("selected");
        node.setAttribute("aria-pressed", "true");
        if (selectedObjects.length > 1) {
          node.classList.add("multi");
        }
      });
      app.classList.add("inspector-open");
      updateContextState();
    }

    function getObjectZ(node) {
      return Number(node.dataset.z || 2);
    }

    function setObjectZ(node, value) {
      const next = Math.max(1, value);
      node.dataset.z = String(next);
      node.style.zIndex = next;
    }

    function alignSelection(direction) {
      if (!selectedObjects.length) return;
      const padding = 72;
      selectedObjects.forEach((node) => {
        if (direction === "left") {
          node.style.left = padding + "px";
        } else if (direction === "center") {
          node.style.left = ((cert.clientWidth - node.offsetWidth) / 2) + "px";
        } else if (direction === "right") {
          node.style.left = (cert.clientWidth - padding - node.offsetWidth) + "px";
        }
      });
      showToast("Selection aligned " + direction);
    }

    function distributeSelection(axis) {
      if (selectedObjects.length < 2) return;
      const ordered = selectedObjects.slice().sort((a, b) => axis === "horizontal"
        ? parseFloat(a.style.left) - parseFloat(b.style.left)
        : parseFloat(a.style.top) - parseFloat(b.style.top));
      const first = ordered[0];
      const last = ordered[ordered.length - 1];
      const start = axis === "horizontal" ? parseFloat(first.style.left) : parseFloat(first.style.top);
      const end = axis === "horizontal" ? parseFloat(last.style.left) : parseFloat(last.style.top);
      const step = ordered.length > 1 ? (end - start) / (ordered.length - 1) : 0;
      ordered.forEach((node, index) => {
        if (axis === "horizontal") {
          node.style.left = start + step * index + "px";
        } else {
          node.style.top = start + step * index + "px";
        }
      });
      showToast("Selection distributed " + axis);
    }

    function nudgeSelection(dx, dy) {
      if (!selectedObjects.length) return;
      selectedObjects.forEach((node) => {
        node.style.left = parseFloat(node.style.left) + dx + "px";
        node.style.top = parseFloat(node.style.top) + dy + "px";
      });
      renderLayerList();
    }

    function duplicateSelection() {
      if (!selectedObjects.length) return;
      const clones = selectedObjects.map((node) => {
        const clone = node.cloneNode(true);
        clone.classList.remove("selected", "multi");
        clone.style.left = (parseFloat(node.style.left) + 18) + "px";
        clone.style.top = (parseFloat(node.style.top) + 18) + "px";
        clone.style.zIndex = String(getObjectZ(node) + 1);
        clone.dataset.z = clone.style.zIndex;
        cert.appendChild(clone);
        registerObject(clone);
        designObjects.push(clone);
        return clone;
      });
      setSelectionState(clones);
      showToast(clones.length > 1 ? "Objects duplicated" : "Object duplicated");
    }

    function deleteSelection() {
      if (!selectedObjects.length) return;
      selectedObjects.forEach((node) => {
        const index = designObjects.indexOf(node);
        if (index >= 0) designObjects.splice(index, 1);
        node.remove();
      });
      setSelectionState([]);
      showToast("Selection deleted");
    }

    function moveSelectionLayer(direction) {
      if (!selectedObjects.length) return;
      selectedObjects.forEach((node) => {
        setObjectZ(node, getObjectZ(node) + direction);
      });
      renderLayerList();
      showToast(direction > 0 ? "Selection brought forward" : "Selection sent backward");
    }

    function moveSelectionToEdge(direction) {
      if (!selectedObjects.length) return;
      const selectedSet = new Set(selectedObjects);
      const ordered = designObjects.slice().sort((a, b) => getObjectZ(a) - getObjectZ(b));
      const unselected = ordered.filter((node) => !selectedSet.has(node));
      const nextOrder = direction > 0
        ? [...unselected, ...selectedObjects]
        : [...selectedObjects, ...unselected];
      nextOrder.forEach((node, index) => {
        setObjectZ(node, index + 1);
      });
      renderLayerList();
      showToast(direction > 0 ? "Selection moved to front" : "Selection sent to back");
    }

    function updateZoom() {
      zoomTop.textContent = zoom + "%";
      zoomBottom.textContent = zoom + "%";
      rulerFrame.style.transform = "scale(" + zoom / 100 + ")";
    }

    function hsvToRgb(h, s, v) {
      const c = v * s;
      const x = c * (1 - Math.abs((h / 60) % 2 - 1));
      const m = v - c;
      let r = 0, g = 0, b = 0;
      if (h >= 0 && h < 60) [r, g, b] = [c, x, 0];
      else if (h < 120) [r, g, b] = [x, c, 0];
      else if (h < 180) [r, g, b] = [0, c, x];
      else if (h < 240) [r, g, b] = [0, x, c];
      else if (h < 300) [r, g, b] = [x, 0, c];
      else [r, g, b] = [c, 0, x];
      return {
        r: Math.round((r + m) * 255),
        g: Math.round((g + m) * 255),
        b: Math.round((b + m) * 255)
      };
    }

    function rgbToHex(r, g, b) {
      return "#" + [r, g, b].map((value) => value.toString(16).padStart(2, "0")).join("").toUpperCase();
    }

    function hexToRgb(hex) {
      const clean = hex.replace("#", "").trim();
      if (clean.length !== 6) return { r: 238, g: 251, b: 255 };
      return {
        r: parseInt(clean.slice(0, 2), 16),
        g: parseInt(clean.slice(2, 4), 16),
        b: parseInt(clean.slice(4, 6), 16)
      };
    }

    function rgbToHsv(r, g, b) {
      const rn = r / 255;
      const gn = g / 255;
      const bn = b / 255;
      const max = Math.max(rn, gn, bn);
      const min = Math.min(rn, gn, bn);
      const d = max - min;
      let h = 0;
      if (d) {
        if (max === rn) h = ((gn - bn) / d) % 6;
        else if (max === gn) h = (bn - rn) / d + 2;
        else h = (rn - gn) / d + 4;
      }
      h = Math.round(h * 60);
      if (h < 0) h += 360;
      const s = max === 0 ? 0 : d / max;
      const v = max;
      return { h, s, v };
    }

    function updateShapeFill(node, color) {
      node.dataset.color = color;
      const grass = node.querySelector(".grass");
      if (grass) {
        grass.style.background = color;
      } else {
        node.style.background = color;
      }
    }

    function resolveColorRole(role) {
      if (role) return role;
      if (!activeColorTarget) return "page";
      if (activeColorTarget.id === "pageColorTrigger") return "page";
      if (activeColorTarget.id === "textColorTrigger") return "text";
      if (activeColorTarget.id === "shapeColorTrigger") return "shape";
      return "page";
    }

    function applyColor(hex, backgroundValue, role) {
      const color = hex.toUpperCase();
      pickerHex.value = color;
      const resolvedRole = resolveColorRole(role);

      if (resolvedRole === "page") {
        cert.style.background = backgroundValue || color;
        pageColorTrigger.dataset.color = color;
        pageColorTrigger.style.background = color;
        pageColorValue.value = color;
      } else if (resolvedRole === "text") {
        selectedObjects.filter((node) => node.dataset.objectType === "text").forEach((node) => {
          node.style.color = color;
          node.dataset.color = color;
        });
        textColorTrigger.dataset.color = color;
        textColorTrigger.style.background = color;
        textColorValue.value = color;
      } else if (resolvedRole === "shape") {
        selectedObjects.filter((node) => node.dataset.objectType === "shape").forEach((node) => {
          updateShapeFill(node, color);
        });
        shapeColorTrigger.dataset.color = color;
        shapeColorTrigger.style.background = color;
        shapeColorValue.value = color;
      }
    }

    function renderPicker() {
      const rgb = hsvToRgb(pickerState.h, 1, 1);
      pickerSv.style.background = "rgb(" + rgb.r + "," + rgb.g + "," + rgb.b + ")";
      pickerHandle.style.left = pickerState.s * 100 + "%";
      pickerHandle.style.top = (1 - pickerState.v) * 100 + "%";
      hueRange.value = pickerState.h;
      alphaRange.value = Math.round(pickerState.a * 100);
      pickerAlphaValue.textContent = Math.round(pickerState.a * 100) + "%";
      const result = hsvToRgb(pickerState.h, pickerState.s, pickerState.v);
      const hex = rgbToHex(result.r, result.g, result.b);
      pickerHex.value = hex;
      if (activeColorTarget) {
        applyColor(hex, undefined, resolveColorRole());
      }
    }

    function openColorPicker(trigger) {
      activeColorTarget = trigger;
      const rgb = hexToRgb(trigger.dataset.color || "#EEFBFF");
      const hsv = rgbToHsv(rgb.r, rgb.g, rgb.b);
      pickerState = { h: hsv.h, s: hsv.s, v: hsv.v, a: 1 };
      renderPicker();
      const rect = trigger.getBoundingClientRect();
      const left = Math.min(window.innerWidth - 348, rect.left);
      const top = Math.min(window.innerHeight - 480, rect.bottom + 10);
      colorPopover.style.left = Math.max(12, left) + "px";
      colorPopover.style.top = Math.max(12, top) + "px";
      colorPopover.classList.add("show");
    }

    function updateSvFromPointer(event) {
      const rect = pickerSv.getBoundingClientRect();
      pickerState.s = clamp((event.clientX - rect.left) / rect.width, 0, 1);
      pickerState.v = 1 - clamp((event.clientY - rect.top) / rect.height, 0, 1);
      renderPicker();
    }

    document.getElementById("sidebarToggle").addEventListener("click", () => {
      toggleToolPanel();
    });
    document.getElementById("sidebarCollapse").addEventListener("click", () => {
      closeToolPanel();
    });
    toolNavButtons.forEach((button) => {
      button.setAttribute("aria-pressed", button.classList.contains("active") ? "true" : "false");
      button.addEventListener("click", () => {
        if (activeTool === button.dataset.tool && !app.classList.contains("toolpanel-closed")) {
          closeToolPanel();
          return;
        }
        openTool(button.dataset.tool);
      });
    });
    toolpanelBody.addEventListener("scroll", () => {
      if (activeTool) {
        toolScrollPositions[activeTool] = toolpanelBody.scrollTop;
      }
    });
    document.getElementById("docName").addEventListener("keydown", (event) => {
      if (event.key === "Enter") {
        event.preventDefault();
        event.target.blur();
      }
    });
    document.getElementById("inspectorClose").addEventListener("click", () => {
      if (window.innerWidth <= 1080) {
        app.classList.remove("inspector-open");
      } else {
        setSelectionState([]);
      }
    });

    document.querySelectorAll("[data-toast]").forEach((button) => {
      button.addEventListener("click", () => showToast(button.dataset.toast));
    });

    document.querySelectorAll(".panel-tab").forEach((button) => {
      button.addEventListener("click", () => {
        const group = button.closest("[data-tab-group]");
        if (!group) return;
        const target = button.dataset.tabTarget;
        group.querySelectorAll(".panel-tab").forEach((tab) => tab.classList.remove("active"));
        button.classList.add("active");
        const scope = group.parentElement;
        scope.querySelectorAll(".panel-pane").forEach((pane) => {
          pane.classList.toggle("active", pane.dataset.tabPanel === target);
        });
        syncAllAccordionHeights();
      });
    });

    document.querySelectorAll(".inspect-head").forEach((button) => {
      button.setAttribute("aria-expanded", button.parentElement.classList.contains("open") ? "true" : "false");
      button.addEventListener("click", () => {
        button.parentElement.classList.toggle("open");
        button.setAttribute("aria-expanded", button.parentElement.classList.contains("open") ? "true" : "false");
      });
    });

    document.querySelectorAll(".template-card").forEach((card) => {
      card.addEventListener("click", () => {
        document.querySelectorAll(".template-card").forEach((node) => node.classList.remove("selected"));
        card.classList.add("selected");
        showToast("Template applied");
      });
    });

    document.querySelectorAll(".theme-btn").forEach((button) => {
      button.addEventListener("click", () => {
        document.querySelectorAll(".theme-btn").forEach((node) => node.classList.remove("on"));
        button.classList.add("on");
        showToast(button.textContent.trim() + " theme selected");
      });
    });

    document.querySelectorAll(".color-trigger").forEach((trigger) => {
      trigger.addEventListener("click", (event) => {
        event.stopPropagation();
        openColorPicker(trigger);
      });
    });

    pageColorValue.addEventListener("change", () => {
      applyColor(normalizeHex(pageColorValue.value, "#EEFBFF"), undefined, "page");
    });
    textColorValue.addEventListener("change", () => {
      applyColor(normalizeHex(textColorValue.value, "#4C3420"), undefined, "text");
    });
    shapeColorValue.addEventListener("change", () => {
      applyColor(normalizeHex(shapeColorValue.value, "#9DD86F"), undefined, "shape");
    });

    document.querySelectorAll(".picker-swatch").forEach((button) => {
      button.addEventListener("click", () => {
        const rgb = hexToRgb(button.dataset.color);
        const hsv = rgbToHsv(rgb.r, rgb.g, rgb.b);
        pickerState.h = hsv.h;
        pickerState.s = hsv.s;
        pickerState.v = hsv.v;
        renderPicker();
      });
    });

    document.querySelectorAll(".bg-choice").forEach((button) => {
      button.addEventListener("click", () => {
        document.querySelectorAll(".bg-choice").forEach((node) => node.classList.remove("selected"));
        button.classList.add("selected");
        applyColor(button.dataset.color, button.dataset.bg, "page");
        showToast(button.querySelector(".asset-info strong").textContent + " applied");
      });
    });

    alignLeftBtn.addEventListener("click", () => alignSelection("left"));
    alignCenterBtn.addEventListener("click", () => alignSelection("center"));
    alignRightBtn.addEventListener("click", () => alignSelection("right"));
    distributeHorizontalBtn.addEventListener("click", () => distributeSelection("horizontal"));
    distributeVerticalBtn.addEventListener("click", () => distributeSelection("vertical"));
    bringForwardBtn.addEventListener("click", () => moveSelectionLayer(1));
    sendBackwardBtn.addEventListener("click", () => moveSelectionLayer(-1));
    bringToFrontBtn.addEventListener("click", () => moveSelectionToEdge(1));
    sendToBackBtn.addEventListener("click", () => moveSelectionToEdge(-1));
    duplicateBtn.addEventListener("click", duplicateSelection);
    deleteBtn.addEventListener("click", deleteSelection);
    arrangeFrontBtn.addEventListener("click", () => moveSelectionToEdge(1));
    arrangeBackBtn.addEventListener("click", () => moveSelectionToEdge(-1));
    duplicateQuickBtn.addEventListener("click", duplicateSelection);
    rulerToggle.addEventListener("click", () => {
      app.classList.toggle("rulers-hidden");
      rulerToggle.classList.toggle("off", app.classList.contains("rulers-hidden"));
      rulerToggle.setAttribute("aria-pressed", app.classList.contains("rulers-hidden") ? "false" : "true");
      showToast(app.classList.contains("rulers-hidden") ? "Rulers hidden" : "Rulers shown");
    });
    layerList.addEventListener("click", (event) => {
      const item = event.target.closest(".layer-item");
      if (!item) return;
      const match = designObjects.find((node) => node.dataset.objectId === item.dataset.layerId);
      if (!match) return;
      setSelectionState([match]);
    });

    canvasScroll.addEventListener("click", (event) => {
      if (!event.target.closest(".design-object")) {
        setSelectionState([]);
      }
    });

    document.addEventListener("click", (event) => {
      if (!colorPopover.contains(event.target) && !event.target.closest(".color-trigger")) {
        colorPopover.classList.remove("show");
      }
    });

    document.addEventListener("keydown", (event) => {
      const tag = event.target.tagName;
      if (event.target.isContentEditable || tag === "INPUT" || tag === "TEXTAREA" || tag === "SELECT") {
        return;
      }
      const mod = event.ctrlKey || event.metaKey;
      if (mod && event.key.toLowerCase() === "d") {
        event.preventDefault();
        duplicateSelection();
      }
      if (mod && (event.key === "=" || event.key === "+")) {
        event.preventDefault();
        zoom = clamp(zoom + 10, 40, 160);
        updateZoom();
      }
      if (mod && event.key === "-") {
        event.preventDefault();
        zoom = clamp(zoom - 10, 40, 160);
        updateZoom();
      }
      if (event.key === "Escape" && selectedObjects.length) {
        event.preventDefault();
        setSelectionState([]);
      }
      if ((event.key === "Delete" || event.key === "Backspace") && selectedObjects.length) {
        event.preventDefault();
        deleteSelection();
      }
      if (mod && event.key === "]") {
        event.preventDefault();
        if (event.shiftKey) {
          moveSelectionToEdge(1);
        } else {
          moveSelectionLayer(1);
        }
      }
      if (mod && event.key === "[") {
        event.preventDefault();
        if (event.shiftKey) {
          moveSelectionToEdge(-1);
        } else {
          moveSelectionLayer(-1);
        }
      }
      const step = event.shiftKey ? 10 : 1;
      if (event.key === "ArrowLeft" && selectedObjects.length) {
        event.preventDefault();
        nudgeSelection(-step, 0);
      }
      if (event.key === "ArrowRight" && selectedObjects.length) {
        event.preventDefault();
        nudgeSelection(step, 0);
      }
      if (event.key === "ArrowUp" && selectedObjects.length) {
        event.preventDefault();
        nudgeSelection(0, -step);
      }
      if (event.key === "ArrowDown" && selectedObjects.length) {
        event.preventDefault();
        nudgeSelection(0, step);
      }
    });

    let svDragging = false;
    pickerSv.addEventListener("pointerdown", (event) => {
      svDragging = true;
      updateSvFromPointer(event);
    });
    window.addEventListener("pointermove", (event) => {
      if (svDragging) updateSvFromPointer(event);
    });
    window.addEventListener("pointerup", () => {
      svDragging = false;
    });

    hueRange.addEventListener("input", () => {
      pickerState.h = Number(hueRange.value);
      renderPicker();
    });
    alphaRange.addEventListener("input", () => {
      pickerState.a = Number(alphaRange.value) / 100;
      pickerAlphaValue.textContent = alphaRange.value + "%";
    });
    pickerHex.addEventListener("change", () => {
      const rgb = hexToRgb(pickerHex.value);
      const hsv = rgbToHsv(rgb.r, rgb.g, rgb.b);
      pickerState.h = hsv.h;
      pickerState.s = hsv.s;
      pickerState.v = hsv.v;
      renderPicker();
    });

    document.getElementById("zoomIn").addEventListener("click", () => {
      zoom = clamp(zoom + 10, 40, 160);
      updateZoom();
    });
    document.getElementById("zoomOut").addEventListener("click", () => {
      zoom = clamp(zoom - 10, 40, 160);
      updateZoom();
    });

    document.getElementById("btnPreview").addEventListener("click", (event) => runAsyncFeedback(event.currentTarget, "Preview opened"));
    document.getElementById("btnExport").addEventListener("click", (event) => runAsyncFeedback(event.currentTarget, "Export options opened"));
    document.getElementById("btnShare").addEventListener("click", (event) => runAsyncFeedback(event.currentTarget, "Share options opened"));
    document.getElementById("generateTemplateBtn").addEventListener("click", (event) => runAsyncFeedback(event.currentTarget, "Professional template generation started", 900));
    window.addEventListener("resize", syncAllAccordionHeights);

    designObjects.forEach(registerObject);
    applyColor("#EEFBFF", "linear-gradient(180deg,#eefbff 0%,#ffffff 58%,#eefae5 100%)", "page");
    rulerToggle.classList.remove("off");
    rulerToggle.setAttribute("aria-pressed", "true");
    openTool("templates", false);
    updateZoom();
    setSelectionState([]);
    syncAllAccordionHeights();
  </script>
</body>
</html>
