      <button class="picker-swatch" data-color="#F8FBFF" style="background:#f8fbff"></button>
      <button class="picker-swatch" data-color="#FFD76A" style="background:#ffd76a"></button>
      <button class="picker-swatch" data-color="#9DD86F" style="background:#9dd86f"></button>
      <button class="picker-swatch" data-color="#4C3420" style="background:#4c3420"></button>
      <button class="picker-swatch" data-color="#635BFF" style="background:#635bff"></button>
      <button class="picker-swatch" data-color="#0F172A" style="background:#0f172a"></button>
      <button class="picker-swatch" data-color="#FFFFFF" style="background:#ffffff"></button>
      <button class="picker-swatch" data-color="#E2E8F0" style="background:#e2e8f0"></button>
      <button class="picker-swatch" data-color="#C5E8F8" style="background:#c5e8f8"></button>
      <button class="picker-swatch" data-color="#FDE68A" style="background:#fde68a"></button>
      <button class="picker-swatch" data-color="#BBF7D0" style="background:#bbf7d0"></button>
